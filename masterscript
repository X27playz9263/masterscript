#!/bin/bash
clear
mkdir -p /home/$USER/scripts/trash
cd /home/$USER/scripts/
if [ ! -f new ]; then
	cat << 'EOF' > new
#!/bin/bash
clear
echo "Type in the name of your new script"
read name
echo "Type file extension"
read ext
cd /home/$USER/scripts
nano $name.$ext
chmod +x $name.$ext
cd /home/$USER/
./masterscript
EOF
fi
if [ ! -f remove ]; then
        cat << 'EOF' > remove
#!/bin/bash
clear
echo "Remove a script"
cd /home/$USER/scripts
echo "Bash:"
ls *.sh
echo "Python:"
ls *.py
read remove
echo "Deleted $remove"
mv $remove /home/$USER/scripts/trash/
sleep 1
cd /home/$USER
./masterscript
EOF
fi

if [ ! -f edit ]; then
        cat << 'EOF' > edit
#!/bin/bash
clear
cd /home/$USER/scripts/
echo "Type the file you want to edit"
echo "Bash:"
ls *.sh
echo "Python:"
ls *.py
read file
nano $file
cd /home/$USER/
./masterscript
EOF
fi

if [ ! -f restore ]; then
        cat << 'EOF' > restore
#!/bin/bash
clear
cd /home/$USER
echo "Type the item you want to restore"
ls scripts/trash/
read item
if [ "$item" == "erase" ]; then
        ./scripts/erase
else
        mv scripts/trash/$item scripts/
        echo "$item restored"
fi
sleep 2
cd /home/$USER/
./masterscript
EOF
fi

if [ ! -f erase ]; then
        cat << 'EOF' > erase
#!/bin/bash
cd /home/$USER/scripts/trash
ls
echo "Are you sure you want to delete everything in /trash?
[type Yes to delete or anything else to exit]"
read confirm
if [[ $confirm == "Yes" ]]; then
        rm -rf *
        echo "Trash Deleted"
else
        echo "No files were deleted."
fi
sleep 2
cd /home/$USER/
./masterscript
EOF
fi

if [ ! -f help ]; then
        cat << 'EOF' > help
#!/bin/bash
clear
echo "To run a script using Masterscript, type in the name of the script [example = script.sh]"
echo "To remove a script from the folder, type 'remove', this wll move it to a trash folder /scripts/trash"
echo "To restore a script from trash, type 'restore'"
echo "To erase the trash folder,  'type erase'"
echo "To make a new script, type 'new' [Don't forget #!/bin/bash !]"
echo "To edit a script, type 'edit'"
echo "To go back to masterscript, press enter"
read confirm
cd /home/$USER/
./masterscript
EOF
fi

chmod +x *
echo "run 'help' for instructions"
echo "You are currently logged in as $USER on $HOSTNAME"
cd /home/$USER/scripts
echo "$PWD"
echo "Type the script's name to open it"
echo "Bash:"
ls *.sh
echo "Python:"
ls *.py
read program
if [[ $program == *.py ]]; then
	echo "Launching $program..."
	sleep 1
	clear
	python3 $program
elif [[ $program == *.sh ]]; then
	echo "Launching $program..."
	sleep 1
	clear
	./$program
elif [[ $program == "exit" ]]; then
	echo "Exiting masterscript..."
	exit 1
else
	./$program
fi
sleep 2
cd /home/$USER/
./masterscript
